{
  "name": "Club Website Workspace",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint", "esbenp.prettier-vscode"]
    }
  },
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "npm dev server",
      "onAutoForward": "notify",
      "protocol": "http"
    }
  }
  // "postCreateCommand": "mkcert localhost 127.0.0.1",
